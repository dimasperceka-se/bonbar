# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bonbarang

# Secret used to sign JWT auth tokens (change in production)
JWT_SECRET=change-me-in-production

# Port the API server listens on (single-port deployment serves API + static frontend on this)
PORT=9091

# Base URL prefix for the frontend (use "/" for root deployment)
BASE_PATH=/

# OpenAI (optional — required only for the /api/parse AI feature)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
